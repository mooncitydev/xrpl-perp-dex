# Dev nginx config (no TLS, for Docker compose testing)
server {
    listen 80;

    location /v1/orders           { proxy_pass http://orchestrator:3000; }
    location /v1/account/         { proxy_pass http://orchestrator:3000; }
    location /v1/markets/         { proxy_pass http://orchestrator:3000; }
    location /v1/markets          { proxy_pass http://orchestrator:3000; }
    location /v1/openapi.json     { proxy_pass http://orchestrator:3000; }
    location /v1/attestation/     { proxy_pass http://orchestrator:3000; }
    location /v1/withdraw         { proxy_pass http://orchestrator:3000; }

    location /ws {
        proxy_pass http://orchestrator:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }

    location / { return 403; }

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
}
